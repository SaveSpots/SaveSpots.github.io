{
  "expo": {
    "name": "SaveSpots",
    "slug": "savespots",
    "scheme": "savespots",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#5a2532"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.savespots.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SaveSpots uses your location to show nearby SaveBoxes and to tag a new SaveBox you submit."
      }
    },
    "android": {
      "package": "org.savespots.app",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF6F3"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SaveSpots uses your location to show nearby SaveBoxes and to tag a new SaveBox you submit."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
