{
  "name": "savespots-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "web": "pnpm --filter @savespots/web",
    "web:dev": "pnpm --filter @savespots/web dev",
    "web:build": "pnpm --filter @savespots/web build",
    "mobile": "pnpm --filter @savespots/mobile",
    "mobile:start": "pnpm --filter @savespots/mobile start"
  }
}
